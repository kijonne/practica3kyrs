### 1. UserCredentials.cs (самое важное исправление)
```csharp
using CommunityToolkit.Mvvm.ComponentModel;
using System.ComponentModel.DataAnnotations;

namespace HelloApp.ViewModels;

public partial class UserCredentials : ObservableValidator
{
    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Логин обязателен")]
    [MinLength(3, ErrorMessage = "Минимум 3 символа")]
    [MaxLength(20, ErrorMessage = "Максимум 20 символов")]
    [RegularExpression(@"^[a-zA-Z0-9_]+$", ErrorMessage = "Только латинские буквы, цифры и _")]
    private string login = string.Empty;

    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Пароль обязателен")]
    [MinLength(8, ErrorMessage = "Минимум 8 символов")]
    [RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\W).{8,}$",
        ErrorMessage = "Должен содержать A-Z, a-z и спецсимвол")]
    private string password = string.Empty;

    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Подтверждение пароля обязательно")]
    [Compare(nameof(Password), ErrorMessage = "Пароли не совпадают")]
    private string confirmPassword = string.Empty;

    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Email обязателен")]
    [EmailAddress(ErrorMessage = "Некорректный email")]
    private string email = string.Empty;

    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Телефон обязателен")]
    [RegularExpression(@"^\+?\d{10,15}$", ErrorMessage = "Некорректный номер (пример: +79991234567)")]
    private string phoneNumber = string.Empty;
}
```

### 2. RegistrationViewModel.cs (исправленный)
```csharp
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;

namespace HelloApp.ViewModels;

public partial class RegistrationViewModel : ViewModelBase
{
    [ObservableProperty]
    private UserCredentials credentials = new();

    [RelayCommand]
    private void Submit()
    {
        Credentials.ValidateAllProperties();   // ← вот здесь была ошибка

        if (!Credentials.HasErrors)
        {
            // Просто сообщение в консоль (в Avalonia MessageBox нет по умолчанию)
            System.Console.WriteLine("✅ Регистрация прошла успешно!");
            // Или можно добавить TextBlock со статусом в разметку (если хочешь — скажи, добавлю)
        }
    }
}
```

### 3. RegistrationView.axaml (без изменений, но на всякий случай)
(оставляю тот же, что давал раньше — он уже правильный)

```xml
<UserControl ... x:DataType="vm:RegistrationViewModel">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="40" MaxWidth="500">

            <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />

            <!-- Логин -->
            <StackPanel Spacing="5">
                <TextBlock Text="Логин" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="Введите логин" Text="{Binding Credentials.Login}" />
                </DataValidationErrors>
            </StackPanel>

            <!-- Пароль -->
            <StackPanel Spacing="5">
                <TextBlock Text="Пароль" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="Введите пароль" PasswordChar="•" Text="{Binding Credentials.Password}" />
                </DataValidationErrors>
            </StackPanel>

            <!-- Подтверждение пароля -->
            <StackPanel Spacing="5">
                <TextBlock Text="Подтверждение пароля" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="Повторите пароль" PasswordChar="•" Text="{Binding Credentials.ConfirmPassword}" />
                </DataValidationErrors>
            </StackPanel>

            <!-- Email -->
            <StackPanel Spacing="5">
                <TextBlock Text="Email" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="your@email.com" Text="{Binding Credentials.Email}" />
                </DataValidationErrors>
            </StackPanel>

            <!-- Телефон -->
            <StackPanel Spacing="5">
                <TextBlock Text="Номер телефона" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="+7 (999) 123-45-67" Text="{Binding Credentials.PhoneNumber}" />
                </DataValidationErrors>
            </StackPanel>

            <Button Content="Зарегистрироваться" 
                    HorizontalAlignment="Center"
                    Padding="40,14"
                    Command="{Binding SubmitCommand}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
```

