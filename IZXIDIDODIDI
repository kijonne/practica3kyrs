### showTable.php — фильтрация по цене, названию и описанию

Замени весь `showTable.php`:

```php
<?php
require_once 'connection.php';

$conn = new mysqli($host, $user, $password, $database);

if ($conn->connect_error) {
    die("Ошибка подключения: " . $conn->connect_error);
}

// Сортировка
$sortBy = '';
if (isset($_GET['sortBy'])) {
    $allowed = ['name', 'price'];
    if (in_array($_GET['sortBy'], $allowed)) {
        $sortBy = $_GET['sortBy'];
    }
}

// 5.4 — сброс фильтра
$filterActive = false;
if (isset($_GET['filter']) && $_GET['filter'] == 'yes') {
    $filterActive = true;
}

// Строим запрос
$query = "SELECT * FROM games WHERE 1=1";

// 5.2 — фильтр по цене
if ($filterActive && isset($_GET['price']) && $_GET['price'] != '') {
    $price = (float)$_GET['price'];
    $query .= " AND price <= $price";
}

// 5.3 — фильтр по названию
if ($filterActive && isset($_GET['name']) && $_GET['name'] != '') {
    $name = $conn->real_escape_string($_GET['name']);
    $query .= " AND name LIKE '%$name%'";
}

// 5.3 — фильтр по описанию
if ($filterActive && isset($_GET['desc']) && $_GET['desc'] != '') {
    $desc = $conn->real_escape_string($_GET['desc']);
    $query .= " AND description LIKE '%$desc%'";
}

// Сортировка
if ($sortBy != '') {
    $query .= " ORDER BY " . $sortBy;
}

$result = $conn->query($query);
?>

<!DOCTYPE html>
<html>
