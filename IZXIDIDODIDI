           value="<?= isset($_GET['price']) ? $_GET['price'] : '' ?>">
    
    <input type="text" name="name" 
           placeholder="Название"
           value="<?= isset($_GET['name']) ? $_GET['name'] : '' ?>">
    
    <input type="text" name="desc" 
           placeholder="Описание"
           value="<?= isset($_GET['desc']) ? $_GET['desc'] : '' ?>">
    
