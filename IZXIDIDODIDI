### showList.php — пагинация + фильтр по категории

Замени весь `showList.php`:

```php
<?php
require_once 'connection.php';

$conn = new mysqli($host, $user, $password, $database);

if ($conn->connect_error) {
    die("Ошибка подключения: " . $conn->connect_error);
}

// 5.1 — пагинация
$N = 3; // количество товаров на странице

// Получаем общее количество товаров
$countResult = $conn->query("SELECT COUNT(*) FROM games");
$countRow = $countResult->fetch_row();
$totalGames = $countRow[0];
$totalPages = ceil($totalGames / $N);

// 5.5 — фильтр по категории
$categoryFilter = '';
$query = "SELECT * FROM games";

if (isset($_GET['category']) && $_GET['category'] != '') {
    $category = $conn->real_escape_string($_GET['category']);
    $query .= " WHERE category = '$category'";
    $categoryFilter = $_GET['category'];
}

// 5.1.2 — добавляем LIMIT если есть параметр page
$page = 1;
if (isset($_GET['page'])) {
    $page = (int)$_GET['page'];
}
$offset = ($page - 1) * $N;
$query .= " LIMIT $offset, $N";

$result = $conn->query($query);

// Получаем все категории для меню
$categories = $conn->query("SELECT DISTINCT category FROM games");
?>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Список игр</title>
    <style>
        body { font-family: Arial; margin: 20px; }
        .menu { margin-bottom: 20px; }
        .menu a { margin-right: 10px; }
        .active { font-weight: bold; color: gray; pointer-events: none; }
        .pagination { margin-top: 20px; }
        .pagination a { margin-right: 5px; }
        .current-page { font-weight: bold; }
        hr { margin: 15px 0; }
    </style>
</head>
<body>

<h1>Список товаров</h1>

<!-- 5.5 — меню категорий -->
<div class="menu">
    <strong>Категории: </strong>
    <a href="showList.php" 
       class="<?= $categoryFilter == '' ? 'active' : '' ?>">
        Все
    </a>
    <?php
    while ($cat = $categories->fetch_assoc()) {
        $isActive = ($categoryFilter == $cat['category']);
    ?>
        <a href="showList.php?category=<?= urlencode($cat['category']) ?>"
           class="<?= $isActive ? 'active' : '' ?>">
            <?= $cat['category'] ?>
        </a>
    <?php } ?>
</div>

<!-- Список товаров -->
<?php while ($row = $result->fetch_assoc()) { ?>
    <div>
        <h2><?= $row['name'] ?></h2>
        <p><?= $row['description'] ?></p>
        <p>Цена: <?= number_format($row['price'], 2, '.', ' ') ?> руб.</p>
        <hr>
    </div>
<?php } ?>

<!-- 5.1 — пагинация -->
<div class="pagination">
    <strong>Страницы: </strong>
    <?php for ($i = 1; $i <= $totalPages; $i++) { ?>
        <?php if ($i == $page) { ?>
            <span class="current-page"><?= $i ?></span>
        <?php } else { ?>
            <a href="showList.php?page=<?= $i ?>
                <?= $categoryFilter ? '&category=' . urlencode($categoryFilter) : '' ?>">
                <?= $i ?>
            </a>
        <?php } ?>
    <?php } ?>
</div>

</body>
</html>

<?php $conn->close(); ?>
```

