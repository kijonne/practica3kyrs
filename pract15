### **5.1** — Многострочное поле + кнопка «Сохранить» + Ctrl+S + Esc

```python
from tkinter import *
from tkinter import filedialog, messagebox

root = Tk()
root.title("5.1 Сохранение текста")
root.geometry("600x400")

text = Text(root, wrap=WORD, font=("Consolas", 11))
text.pack(fill=BOTH, expand=True, padx=10, pady=10)

def save_file():
    file = filedialog.asksaveasfilename(
        defaultextension=".txt",
        filetypes=[("Text files", "*.txt"), ("All files", "*.*")]
    )
    if file:
        try:
            with open(file, "w", encoding="utf-8") as f:
                f.write(text.get("1.0", END))
            messagebox.showinfo("Успешно", "Файл сохранён!")
        except Exception as e:
            messagebox.showerror("Ошибка", str(e))

# Кнопка
btn = Button(root, text="Сохранить", command=save_file)
btn.pack(pady=5)

# Ctrl+S
root.bind("<Control-s>", lambda e: save_file())
root.bind("<Control-S>", lambda e: save_file())

# Esc — закрыть
root.bind("<Escape>", lambda e: root.destroy())

root.mainloop()
```

