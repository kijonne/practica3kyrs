### **5.2** — Три поля ввода + bind_class

```python
from tkinter import *

root = Tk()
root.title("5.2 bind_class")
root.geometry("500x300")

Label(root, text="Поле 1:").pack(anchor=W, padx=10, pady=5)
entry1 = Entry(root, width=50)
entry1.pack(padx=10)

Label(root, text="Поле 2:").pack(anchor=W, padx=10, pady=5)
entry2 = Entry(root, width=50)
entry2.pack(padx=10)

Label(root, text="Поле 3:").pack(anchor=W, padx=10, pady=5)
entry3 = Entry(root, width=50)
entry3.pack(padx=10)

info_label = Label(root, text="Активное поле: —", font=("Arial", 12))
info_label.pack(pady=20)

def on_click(event, button="left"):
    # Находим какое поле сейчас в фокусе
    focused = root.focus_get()
    if focused in (entry1, entry2, entry3):
        name = focused.get() or f"Поле {list(root.children.values()).index(focused)+1}"
        if button == "left":
            info_label.config(text=f"Активное поле: {name}")
        else:  # right
            print(f"Правый клик → {name}")

# Подписываемся на все Entry через bind_class
root.bind_class("Entry", "<Button-1>", lambda e: on_click(e, "left"))
root.bind_class("Entry", "<Button-3>", lambda e: on_click(e, "right"))

root.mainloop()
```

