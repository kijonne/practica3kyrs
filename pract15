### **5.4** — Нажатые клавиши

```python
from tkinter import *

root = Tk()
root.title("5.4 Нажатые клавиши")
root.geometry("600x400")

label = Label(root, text="Нажатая клавиша: ", 
              font=("Arial", 14), height=5)
label.pack(expand=True)

def key_pressed(event):
    if event.char:  # только печатные символы
        current = label.cget("text")
        if current.startswith("Нажатая клавиша: "):
            label.config(text=f"Нажатая клавиша: {event.char}")
        else:
            label.config(text=current + event.char)

root.bind("<Key>", key_pressed)

root.mainloop()
```

