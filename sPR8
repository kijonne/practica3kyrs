## Шаг 4 — WeatherService

Открой существующий `Services/WeatherService.cs` от преподавателя и реализуй три метода:

```csharp
using System.Net.Http.Json;
using WeatherApp.Models;

namespace WeatherApp.Services;

public class WeatherService
{
    private readonly HttpClient _http;
    private readonly string _apiKey;

    public WeatherService(string apiKey)
    {
        _apiKey = apiKey;
        _http = new HttpClient();
    }

    // Метод 1: погода по названию города
    public async Task<WeatherResponse?> GetWeatherByCityNameAsync(string cityName)
    {
        var url = $"https://api.openweathermap.org/data/2.5/weather" +
                  $"?q={cityName}&appid={_apiKey}&units=metric&lang=ru";

        return await _http.GetFromJsonAsync<WeatherResponse>(url);
    }

    // Метод 2: список городов по названию (Geocoding API)
    public async Task<List<GeoLocation>> GetLocationsByNameAsync(string cityName)
    {
        var url = $"https://api.openweathermap.org/geo/1.0/direct" +
                  $"?q={cityName}&limit=5&appid={_apiKey}";

        var result = await _http.GetFromJsonAsync<List<GeoLocation>>(url);
        return result ?? new List<GeoLocation>();
    }

    // Метод 3: погода по координатам
    public async Task<WeatherResponse?> GetWeatherByCoordinatesAsync(double lat, double lon)
    {
        var url = $"https://api.openweathermap.org/data/2.5/weather" +
                  $"?lat={lat}&lon={lon}&appid={_apiKey}&units=metric&lang=ru";

        return await _http.GetFromJsonAsync<WeatherResponse>(url);
    }
}
```

`GetFromJsonAsync` — встроенный метод HttpClient, сам десериализует JSON в нужный класс. Никаких лишних пакетов.

