<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HelloApp.ViewModels"
        x:DataType="vm:MainWindowViewModel"
        Title="HelloApp" Width="800" Height="500">

