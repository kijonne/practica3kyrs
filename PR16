**server_5_3.py** (используется также для 5.4)
```python
import socket
from datetime import datetime

HOST = ''
PORT = 50007

s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.bind((HOST, PORT))
s.listen(1)

# Постоянное прослушивание подключений
while True:
    conn, addr = s.accept()
    
    # Получаем логин сразу после подключения
    login_data = conn.recv(1024)
    login = login_data.decode('utf-8').strip() if login_data else 'unknown'
    print(f'подключился {login}')
    
    while True:
        data = conn.recv(1024)
        if not data:
            break
        message = data.decode('utf-8')
        # Вывод "дата и время логин: сообщение"
        print(datetime.strftime(datetime.now(), "%Y.%m.%d %H:%M:%S") +
              f" {login}: {message}")
    
    conn.close()
```

### 5.4.1 + 5.4.2 — Оконный клиент (работает с server_5_3.py)

**client_gui_5_4.py**
```python
import socket
import tkinter as tk

HOST = 'localhost'
PORT = 50007

def send_message():
    try:
        login = login_entry.get().strip()
        message = message_entry.get().strip()
        
        if not login or not message:
            return
        
        # Действует аналогично клиенту 5.3: connect → login → message
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.connect((HOST, PORT))
            s.sendall(login.encode('utf-8'))
            s.sendall(message.encode('utf-8'))
        
        # Очищаем поле сообщения после отправки
        message_entry.delete(0, tk.END)
    except Exception:
        pass  # без лишних сообщений об ошибках

# Создание окна
root = tk.Tk()
root.title("Чат-клиент")

# Поле логина
tk.Label(root, text="Логин:").pack()
login_entry = tk.Entry(root, width=30)
login_entry.pack()

# Поле сообщения
tk.Label(root, text="Сообщение:").pack()
message_entry = tk.Entry(root, width=30)
message_entry.pack()

# Кнопка "Отправить"
send_btn = tk.Button(root, text="Отправить", command=send_message)
send_btn.pack()

root.mainloop()
```











