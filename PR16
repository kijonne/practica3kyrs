**server_5_2.py**
```python
import socket
from datetime import datetime

HOST = ''
PORT = 50007

s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.bind((HOST, PORT))
s.listen(1)

# Постоянное прослушивание подключений
while True:
    conn, addr = s.accept()
    
    while True:
        data = conn.recv(1024)
        if not data:
            break
        # Вывод "дата и время (адрес клиента): сообщение"
        print(datetime.strftime(datetime.now(), "%Y.%m.%d %H:%M:%S") +
              f" ({addr}): {data.decode('utf-8')}")
    
    conn.close()
```

