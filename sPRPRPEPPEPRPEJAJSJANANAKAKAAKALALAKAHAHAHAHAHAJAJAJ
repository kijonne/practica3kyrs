## Шаг 2 — `WeatherView.axaml` — полностью заменяй

```xml
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WeatherApp.ViewModels"
             xmlns:m="clr-namespace:WeatherApp.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WeatherApp.Views.WeatherView"
             x:DataType="vm:WeatherViewModel">

    <UserControl.DataTemplates>
        <DataTemplate DataType="m:Weather">
            <Border BorderBrush="Gray" BorderThickness="1"
                    CornerRadius="8" Padding="12" Margin="4" Width="200">
                <StackPanel Spacing="4">

                    <!-- Иконка + город -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Image Source="{Binding Image^}" Width="40" Height="40"/>
                        <TextBlock Text="{Binding City.Name}"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding Description}"/>

                    <TextBlock>
                        <Run Text="Температура: "/>
                        <Run Text="{Binding Temperature, StringFormat='{}{0:F0} °C'}"/>
                    </TextBlock>

                    <TextBlock>
                        <Run Text="Ощущается: "/>
                        <Run Text="{Binding FeelsAsTemperature, StringFormat='{}{0:F0} °C'}"/>
                    </TextBlock>

                    <TextBlock>
                        <Run Text="Давление: "/>
                        <Run Text="{Binding Pressure, StringFormat='{}{0:F0} гПа'}"/>
                    </TextBlock>

                    <TextBlock>
                        <Run Text="Влажность: "/>
                        <Run Text="{Binding Humidity, StringFormat='{}{0:F0} %'}"/>
                    </TextBlock>

                    <TextBlock>
                        <Run Text="Ветер: "/>
                        <Run Text="{Binding WindSpeed, StringFormat='{}{0:F1} м/с'}"/>
                    </TextBlock>

                    <TextBlock>
                        <Run Text="Облачность: "/>
                        <Run Text="{Binding Cloudiness, StringFormat='{}{0:F0} %'}"/>
                    </TextBlock>

                    <!-- Кнопки Обновить и Удалить -->
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
                        <Button Content="Обновить"
                                Command="{Binding $parent[UserControl].DataContext.RefreshCardCommand}"
                                CommandParameter="{Binding}"/>
                        <Button Content="Удалить"
                                Command="{Binding $parent[UserControl].DataContext.DeleteCardCommand}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Строка 1: поле ввода + кнопка поиск -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="10">
            <TextBox Watermark="Введите город" Text="{Binding CityInput}" Width="250"/>
            <Button Content="Поиск" Command="{Binding SearchCommand}"/>
        </StackPanel>

        <!-- Строка 2: список найденных городов -->
        <ListBox Grid.Row="1" Margin="10,0,10,10"
                 ItemsSource="{Binding FoundCities}"
                 SelectedItem="{Binding SelectedCity}"
                 MaxHeight="120">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="m:City">
                    <TextBlock>
                        <Run Text="{Binding Name}"/>
                        <Run Text=", "/>
                        <Run Text="{Binding Country}"/>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Строка 3: карточки погоды в ScrollViewer + WrapPanel -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding WeatherCards}" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
```

---

## Что происходит по шагам:

1. Вводишь город → жмёшь **Поиск** → заполняется список городов под полем ввода
2. Выбираешь город из списка → автоматически добавляется карточка погоды
3. Город сохраняется в `Preferences` — при следующем запуске карточки загрузятся сами
4. На каждой карточке **Обновить** (перезапрашивает погоду) и **Удалить** (убирает карточку и из сохранения)

Больше ничего не трогаешь — всё остальное от препода остаётся как есть 👌
