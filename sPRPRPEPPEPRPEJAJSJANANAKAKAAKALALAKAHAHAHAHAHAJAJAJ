## Шаг 1 — `WeatherViewModel.cs` — полностью заменяй

```csharp
using CommunityToolkit.Mvvm.Input;
using System.Collections.ObjectModel;
using System.Threading.Tasks;
using WeatherApp.Extensions;
using WeatherApp.Models;
using WeatherApp.Services;

namespace WeatherApp.ViewModels
{
    public partial class WeatherViewModel : ViewModelBase
    {
        WeatherService _weatherService;

        // Поле ввода
        private string _cityInput = string.Empty;
        public string CityInput
        {
            get => _cityInput;
            set => SetProperty(ref _cityInput, value);
        }

        // Список найденных городов (после поиска)
        public ObservableCollection<City> FoundCities { get; } = new();

        // Выбранный город из списка
        private City? _selectedCity;
        public City? SelectedCity
        {
            get => _selectedCity;
            set
            {
                SetProperty(ref _selectedCity, value);
                // Когда выбрали город — добавляем карточку
                if (value != null)
                    _ = AddWeatherCardAsync(value);
            }
        }

        // Список карточек погоды
        public ObservableCollection<Weather> WeatherCards { get; } = new();

        public WeatherViewModel(WeatherService weatherService)
        {
            _weatherService = weatherService;

            // Загружаем сохранённые города при старте
            InitializationTask = Task.Run(async () =>
            {
                var savedCities = await Preferences.Load<List<City>>("cities", new List<City>());
                foreach (var city in savedCities)
                {
                    var weather = await _weatherService.GetWeatherByGeoAsync(city.Latitude, city.Longitude);
                    Avalonia.Threading.Dispatcher.UIThread.Post(() => WeatherCards.Add(weather));
                }
            });
        }

        TaskNotifier? _initializationTask;
        public Task? InitializationTask
        {
            get => _initializationTask;
            set => SetPropertyAndNotifyOnCompletion(ref _initializationTask, value);
        }

        // Кнопка Поиск — ищет города по названию
        [RelayCommand]
        private async Task SearchAsync()
        {
            if (string.IsNullOrWhiteSpace(CityInput)) return;
            try
            {
                var cities = await _weatherService.GetGeoByCityNameAsync(CityInput, 5);
                FoundCities.Clear();
                foreach (var c in cities)
                    FoundCities.Add(c);
            }
            catch { }
        }

        // Добавление карточки погоды по выбранному городу
        private async Task AddWeatherCardAsync(City city)
        {
            try
            {
                var weather = await _weatherService.GetWeatherByGeoAsync(city.Latitude, city.Longitude);
                WeatherCards.Add(weather);
                await SaveCitiesAsync();
            }
            catch { }
        }

        // Кнопка Удалить на карточке
        [RelayCommand]
        private async Task DeleteCard(Weather weather)
        {
            WeatherCards.Remove(weather);
            await SaveCitiesAsync();
        }

        // Кнопка Обновить на карточке
        [RelayCommand]
        private async Task RefreshCard(Weather weather)
        {
            try
            {
                var updated = await _weatherService.GetWeatherByGeoAsync(
                    weather.City.Latitude, weather.City.Longitude);
                var index = WeatherCards.IndexOf(weather);
                if (index >= 0)
                    WeatherCards[index] = updated;
            }
            catch { }
        }

        // Сохраняем список городов
        private async Task SaveCitiesAsync()
        {
            var cities = WeatherCards.Select(w => w.City).ToList();
            await Preferences.Save("cities", cities);
        }
    }
}
```

