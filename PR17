### 5.1 Интерактивный файловый менеджер (`file_manager.py`)

```python
import os
import shutil
import fnmatch
from datetime import datetime

def list_dir():
    print("\nСодержимое текущей директории:")
    for item in os.listdir():
        full_path = os.path.join(os.getcwd(), item)
        size = os.path.getsize(full_path) if os.path.isfile(full_path) else "<DIR>"
        print(f"{'DIR' if os.path.isdir(full_path) else 'FILE':<6} {item:<30} {size}")

def create_dir():
    name = input("Введите имя новой директории: ").strip()
    if not os.path.exists(name):
        os.mkdir(name)
        print(f"Директория '{name}' успешно создана")
    else:
        print("Такая директория уже существует!")

def create_file():
    name = input("Введите имя нового файла: ").strip()
    content = input("Введите содержимое файла (можно оставить пустым): ")
    with open(name, 'w', encoding='utf-8') as f:
        f.write(content)
    print(f"Файл '{name}' успешно создан")

def delete_item():
    name = input("Введите имя файла или директории для удаления: ").strip()
    if not os.path.exists(name):
        print("Такого пути не существует!")
        return
    if os.path.isfile(name):
        os.remove(name)
        print(f"Файл '{name}' удалён")
    elif os.path.isdir(name):
        if input("Удалить директорию рекурсивно? (y/n): ").lower() == 'y':
            shutil.rmtree(name)
            print(f"Директория '{name}' удалена")
        else:
            os.rmdir(name)
            print(f"Пустая директория '{name}' удалена")

def rename_item():
    old = input("Старое имя: ").strip()
    new = input("Новое имя: ").strip()
    if os.path.exists(old):
        os.rename(old, new)
        print(f"Переименовано: {old} → {new}")
    else:
        print("Исходный файл/директория не найден")

def edit_file():
    name = input("Имя файла для изменения: ").strip()
    if os.path.isfile(name):
        with open(name, 'r', encoding='utf-8') as f:
            print("\nТекущее содержимое:\n" + f.read())
        content = input("\nНовое содержимое файла:\n")
        with open(name, 'w', encoding='utf-8') as f:
            f.write(content)
        print("Файл успешно изменён")
    else:
        print("Файл не найден")

def search_files():
    print("\n=== Поиск файлов ===")
    print("1. По маске (*.txt)")
    print("2. По расширению")
    print("3. По дате модификации (после даты)")
    print("4. По размеру (> байт)")
    choice = input("Выберите критерий: ")

    results = []
    root_dir = os.getcwd()

    if choice == '1':
        mask = input("Введите маску (например *.py): ").strip()
        for root, _, files in os.walk(root_dir):
            for f in files:
                if fnmatch.fnmatch(f, mask):
                    results.append(os.path.join(root, f))

    elif choice == '2':
        ext = input("Введите расширение (txt): ").strip()
        if not ext.startswith('.'):
            ext = '.' + ext
        for root, _, files in os.walk(root_dir):
            for f in files:
                if f.lower().endswith(ext.lower()):
                    results.append(os.path.join(root, f))

    elif choice == '3':
        date_str = input("Введите дату (YYYY-MM-DD): ").strip()
        try:
            target_date = datetime.strptime(date_str, "%Y-%m-%d").timestamp()
            for root, _, files in os.walk(root_dir):
                for f in files:
                    full = os.path.join(root, f)
                    if os.stat(full).st_mtime > target_date:
                        results.append(full)
        except:
            print("Неверный формат даты!")

    elif choice == '4':
        min_size = int(input("Минимальный размер в байтах: "))
        for root, _, files in os.walk(root_dir):
            for f in files:
                full = os.path.join(root, f)
                if os.stat(full).st_size > min_size:
                    results.append(full)

    print(f"\nНайдено {len(results)} файлов:")
    for r in results:
        print(r)

def change_dir():
    path = input("Введите новый путь (или .. для родительской): ").strip()
    try:
        os.chdir(path)
        print("Текущая директория:", os.getcwd())
    except:
        print("Не удалось сменить директорию")

def main():
    print("=== Интерактивный файловый менеджер ===")
    while True:
        print("\nТекущая директория:", os.getcwd())
        print("1. Показать содержимое")
        print("2. Создать директорию")
        print("3. Создать файл")
        print("4. Удалить файл/директорию")
        print("5. Переименовать")
        print("6. Изменить содержимое файла")
        print("7. Поиск файлов")
        print("8. Сменить директорию")
        print("0. Выход")
        choice = input("Выберите действие: ").strip()

        if choice == '1': list_dir()
        elif choice == '2': create_dir()
        elif choice == '3': create_file()
        elif choice == '4': delete_item()
        elif choice == '5': rename_item()
        elif choice == '6': edit_file()
        elif choice == '7': search_files()
        elif choice == '8': change_dir()
        elif choice == '0': 
            print("До свидания!")
            break
        else:
            print("Неверный выбор!")

if __name__ == "__main__":
    main()
```

### 5.2 Диспетчер задач (`task_manager.py`)

```python
import subprocess

def list_processes():
    print("\n=== Список процессов (tasklist) ===")
    result = subprocess.run('tasklist', shell=True, capture_output=True, text=True)
    print(result.stdout)

def kill_process():
    pid = input("Введите PID процесса для завершения: ").strip()
    try:
        subprocess.run(f'taskkill /PID {pid} /F', shell=True, check=True)
        print(f"Процесс с PID {pid} принудительно завершён")
    except:
        print("Не удалось завершить процесс (возможно, нет прав или PID неверный)")

def launch_program():
    cmd = input("Введите команду или путь к программе (например: notepad.exe или calc): ").strip()
    try:
        subprocess.Popen(cmd, shell=True)
        print(f"Программа '{cmd}' запущена")
    except:
        print("Не удалось запустить программу")

def main():
    print("=== Диспетчер задач ===")
    while True:
        print("\n1. Показать список процессов")
        print("2. Запустить программу")
        print("3. Принудительно завершить процесс")
        print("0. Выход")
        choice = input("Выберите действие: ").strip()

        if choice == '1': list_processes()
        elif choice == '2': launch_program()
        elif choice == '3': kill_process()
        elif choice == '0':
            print("До свидания!")
            break
        else:
            print("Неверный выбор!")

if __name__ == "__main__":
    main()
```

### 5.3 Автоматизация по JSON (`json_automator.py`)

```python
import json
import os
import shutil

def execute_command(cmd):
    action = cmd.get("action")
    try:
        if action == "mkdir":
            path = cmd.get("path")
            os.makedirs(path, exist_ok=True)
            print(f"✓ Создана директория: {path}")

        elif action == "create_file":
            path = cmd.get("path")
            content = cmd.get("content", "")
            os.makedirs(os.path.dirname(path), exist_ok=True)
            with open(path, 'w', encoding='utf-8') as f:
                f.write(content)
            print(f"✓ Создан файл: {path}")

        elif action == "delete":
            path = cmd.get("path")
            if os.path.isfile(path):
                os.remove(path)
            elif os.path.isdir(path):
                shutil.rmtree(path)
            print(f"✓ Удалено: {path}")

        elif action == "rename":
            old = cmd.get("old")
            new = cmd.get("new")
            os.rename(old, new)
            print(f"✓ Переименовано: {old} → {new}")

        else:
            print(f"✗ Неизвестная команда: {action}")
    except Exception as e:
        print(f"✗ Ошибка при выполнении {action}: {e}")

def main():
    json_file = input("Введите путь к JSON-файлу (например example.json): ").strip()
    if not os.path.exists(json_file):
        print("JSON-файл не найден!")
        return

    with open(json_file, 'r', encoding='utf-8') as f:
        commands = json.load(f)

    print(f"\nЗапускаю {len(commands)} команд из JSON...\n")
    for cmd in commands:
        execute_command(cmd)
    print("\nАвтоматизация завершена!")

if __name__ == "__main__":
    main()
```

