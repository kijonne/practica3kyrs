### ПР №23 — Конфигурация + DI + Навигация

#### 1. App.axaml.cs (важные изменения)

```csharp
using Avalonia;
using Avalonia.Controls.ApplicationLifetimes;
using Avalonia.Markup.Xaml;
using HelloApp.Services;
using HelloApp.ViewModels;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using System;

namespace HelloApp
{
    public partial class App : Application
    {
        public static IConfiguration Configuration { get; private set; } = null!;
        public static IServiceProvider Services { get; private set; } = null!;

        public override void Initialize()
        {
            AvaloniaXamlLoader.Load(this);
        }

        public override void OnFrameworkInitializationCompleted()
        {
            if (ApplicationLifetime is IClassicDesktopStyleApplicationLifetime desktop)
            {
                // Конфигурация
                var builder = new ConfigurationBuilder();
                builder.AddJsonFile("appsettings.json", optional: false, reloadOnChange: true);
                Configuration = builder.Build();

                // DI
                var collection = new ServiceCollection();
                collection.AddSingleton<NavigationService>();
                collection.AddSingleton<MainWindowViewModel>();
                collection.AddTransient<AuthorizationViewModel>();
                collection.AddTransient<RegistrationViewModel>();
                collection.AddTransient<UserListViewModel>();

                Services = collection.BuildServiceProvider();

                desktop.MainWindow = new MainWindow
                {
                    DataContext = Services.GetRequiredService<MainWindowViewModel>()
                };
            }

            base.OnFrameworkInitializationCompleted();
        }
    }
}
```

