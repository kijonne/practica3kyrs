#### 3. NavigationService.cs (обновлённый под DI)

```csharp
using CommunityToolkit.Mvvm.ComponentModel;
using System;
using System.Collections.Generic;

namespace HelloApp.Services
{
    public partial class NavigationService : ObservableObject
    {
        public static NavigationService Instance => App.Services.GetRequiredService<NavigationService>();

        public Stack<ViewModelBase> Stack { get; } = new();

        [ObservableProperty]
        private ViewModelBase? current;

        public void NavigateTo<T>(Action<T>? action = null) where T : ViewModelBase
        {
            var vm = App.Services.GetRequiredService<T>();
            action?.Invoke(vm);
            NavigateTo(vm);
        }

        public void NavigateTo(ViewModelBase viewModel)
        {
            Stack.Push(viewModel);
            Current = viewModel;
        }

        public void GoBack(int steps = 1)
        {
            if (Stack.Count <= 1) return;

            for (int i = 0; i < steps; i++)
            {
                if (Stack.Count > 1)
                    Stack.Pop();
            }

            Current = Stack.Count > 0 ? Stack.Peek() : null;
        }
    }
}
```

#### 4. MainWindowViewModel.cs (упрощённый)

```csharp
using CommunityToolkit.Mvvm.ComponentModel;
using CommunityToolkit.Mvvm.Input;
using HelloApp.Services;
using HelloApp.ViewModels;

namespace HelloApp.ViewModels
{
    public partial class MainWindowViewModel : ViewModelBase
    {
        private readonly NavigationService _navigation;

        public ViewModelBase? CurrentPage => _navigation.Current;

        public MainWindowViewModel(NavigationService navigation)
        {
            _navigation = navigation;
            _navigation.PropertyChanged += (s, e) => OnPropertyChanged(nameof(CurrentPage));

            // Старт
            _navigation.NavigateTo<AuthorizationViewModel>();
        }

        [RelayCommand] private void GoToAuthorization() => _navigation.NavigateTo<AuthorizationViewModel>();
        [RelayCommand] private void GoToRegistration() => _navigation.NavigateTo<RegistrationViewModel>();
        [RelayCommand] private void GoToUserList() => _navigation.NavigateTo<UserListViewModel>();
        [RelayCommand] private void GoBack() => _navigation.GoBack();
    }
}
