            f.write("Четвёртая строка\n")
            f.write("Пятая строка — важная!\n")
            f.write("Шестая строка\n")
            f.write("Седьмая строка\n")
            f.write("Восьмая строка\n")
        print("Файл создан.")

def analyze_text_file():
    create_sample_file()
    
    if not os.path.exists(FILENAME):
        print("Файл не найден!")
        return
    
    try:
        with open(FILENAME, 'r', encoding='utf-8') as f:
            lines = f.readlines()
        
        print(f"\nФайл: {FILENAME} ({len(lines)} строк)")
        print("1. Первая строка:", lines[0].strip() if len(lines) > 0 else "—")
        print("2. Пятая строка:", lines[4].strip() if len(lines) > 4 else "—")
        print("3. Первые 5 строк:")
        for i in range(min(5, len(lines))):
            print(f"   {i+1}: {lines[i].strip()}")
        
        # Строки с s1 по s2 (пример: 3-6)
        s1, s2 = 3, 6
        print(f"4. Строки с {s1} по {s2}:")
        for i in range(s1-1, min(s2, len(lines))):
            print(f"   {i+1}: {lines[i].strip()}")
        
        print("5. Весь файл:")
        for i, line in enumerate(lines, 1):
            print(f"{i}: {line.strip()}")
            
    except Exception as e:
        print(f"Ошибка: {e}")

if __name__ == "__main__":
    analyze_text_file()




