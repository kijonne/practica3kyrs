import os

def write_to_file():
    filename = input("Введите имя файла для записи: ").strip()
    
    if os.path.exists(filename):
        choice = input("Файл существует. Дописать (a) или перезаписать (w)? ").strip().lower()
        mode = 'a' if choice == 'a' else 'w'
        if mode == 'a':
            print("Будем дописывать в конец файла.")
        else:
            print("Файл будет перезаписан.")
    else:
        mode = 'w'
        print("Файл будет создан.")
    
    print("Вводите текст (каждая строка с новой строки). Для окончания введите 'end'")
    try:
        with open(filename, mode, encoding='utf-8') as f:
            while True:
                line = input()
                if line.strip().lower() == 'end':
                    break
                f.write(line + '\n')
        print(f"Текст успешно записан в '{filename}'")
    except Exception as e:
        print(f"Ошибка: {e}")

if __name__ == "__main__":
    write_to_file()






