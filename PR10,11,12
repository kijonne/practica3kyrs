import os

def file_operations():
    filename = input("Введите имя файла: ").strip()
    
    if not os.path.exists(filename):
        print(f"Ошибка: файл '{filename}' не найден!")
        return
    
    print("\nВыберите операцию:")
    print("1 — Вывести содержимое")
    print("2 — Удалить файл")
    print("3 — Переименовать файл")
    
    choice = input("Введите номер (1/2/3): ").strip()
    
    try:
        if choice == '1':
            with open(filename, 'r', encoding='utf-8') as f:
                print("\nСодержимое:")
                print(f.read())
        
        elif choice == '2':
            confirm = input(f"Удалить '{filename}'? (y/n): ").strip().lower()
            if confirm == 'y':
                os.remove(filename)
                print("Файл успешно удалён.")
        
        elif choice == '3':
            new_name = input("Введите новое имя файла: ").strip()
            if os.path.exists(new_name):
                print("Ошибка: файл с таким именем уже существует!")
            else:
                os.rename(filename, new_name)
                print(f"Файл переименован в '{new_name}'")
        
        else:
            print("Неверный выбор!")
    except Exception as e:
        print(f"Ошибка: {e}")

