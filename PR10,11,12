import re

def find_dates(text):
    pattern = r'\b(0?[1-9]|[12][0-9]|3[01])\.(0?[1-9]|1[0-2])\.(\d{2}|\d{4})\b'
    
    dates = re.findall(pattern, text)
    return dates

if __name__ == "__main__":
    example = "Встреча 15.03.2025 или 01.01.25. " \
              "Ещё 31.12.2024 и 5.6.23. А 32.13.2025 — это уже не дата."
    print("Исходный текст:")
    print(example)
    print("\nНайденные даты:")
    for date in find_dates(example):
        print(f"{date[0]}.{date[1]}.{date[2]}")





