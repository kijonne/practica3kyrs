import re

def replace_bad_words(text):
    pattern = r'\b(редиска|редиски|редисок|редиску|редисками|редисках|' \
              r'нехороший человек|нехорошего человека|нехорошему человеку|' \
              r'нехорошим человеком|нехорошие люди|нехороших людей)\b'

    result = re.sub(pattern, '*давайте жить дружно*', text, flags=re.IGNORECASE)
    return result

