import os

FILENAME = "numbers.txt"

def create_numbers_file():
    if not os.path.exists(FILENAME):
        print(f"Создаём файл {FILENAME} с примерами чисел...")
        with open(FILENAME, 'w', encoding='utf-8') as f:
            f.write("10 20 30\n")
            f.write("5 15\n")
            f.write("100 200 300 400\n")
            f.write("1 2 3 4 5 6\n")
            f.write("   7   8  9 \n") 
        print("Файл создан.")

def sum_numbers_in_lines():
    create_numbers_file()
    
    if not os.path.exists(FILENAME):
        print("Файл не найден!")
        return
    
    try:
        with open(FILENAME, 'r', encoding='utf-8') as f:
            print(f"Файл: {FILENAME}\n")
            for i, line in enumerate(f, 1):
                numbers = [int(x) for x in line.split() if x.isdigit() or (x.startswith('-') and x[1:].isdigit())]
                total = sum(numbers)
                print(f"Строка {i}: {line.strip()} → сумма = {total}")
    except Exception as e:
        print(f"Ошибка: {e}")

if __name__ == "__main__":
    sum_numbers_in_lines()
