```csharp
private void btnDelete_Click(object sender, RoutedEventArgs e)
{
    try
    {
        string query = "DELETE FROM books WHERE book_id = @id";
        
        MySqlParameter[] parameters = {
            new MySqlParameter("@id", txtDeleteId.Text)
        };
        
        int rows = DAL.ExecuteQuery(query, parameters);
        
        if (rows > 0)
            lblDeleteResult.Text = $"Книга удалена!";
        else
            lblDeleteResult.Text = "Книга не найдена.";
    }
    catch (Exception ex)
    {
        lblDeleteResult.Text = $"Ошибка: {ex.Message}";
    }
}
```

