### Шаг 5 — info.php

```php
<?php
require_once 'header.php';

$id = (int)$_GET['id'];

// 5.3.3 — получаем полную информацию о товаре
$stmt = $pdo->prepare("SELECT * FROM games WHERE idGame = ?");
$stmt->execute([$id]);
$game = $stmt->fetch(PDO::FETCH_ASSOC);

if (!$game) {
    echo "<p>Товар не найден!</p>";
    require_once 'footer.php';
    exit;
}

// 5.5.3 — проверяем есть ли товар в корзине
$cartStmt = $pdo->prepare("SELECT * FROM cart WHERE idGame = ?");
$cartStmt->execute([$id]);
$inCart = $cartStmt->fetch(PDO::FETCH_ASSOC);

// 5.5.2 — добавление в корзину
if (isset($_POST['addToCart'])) {
    $insertStmt = $pdo->prepare(
        "INSERT INTO cart (idGame, added_at) VALUES (?, NOW())"
    );
    $insertStmt->execute([$id]);
    $inCart = true;
}

// 5.4.2 — получаем фото товара
$photosStmt = $pdo->prepare("SELECT * FROM photos WHERE idGame = ?");
$photosStmt->execute([$id]);
$photos = $photosStmt->fetchAll(PDO::FETCH_ASSOC);
?>

<!-- 5.3.3 — полная информация -->
<div class="clearfix">
    <?php if (!empty($game['logo'])) { ?>
        <img src="<?= $game['logo'] ?>" alt="<?= $game['name'] ?>">
    <?php } ?>
    
    <h1><?= $game['name'] ?></h1>
</div>

<p><?= $game['description'] ?></p>
<p><strong>Цена: <?= number_format($game['price'], 2, '.', ' ') ?> руб.</strong></p>
<p><strong>Категория:</strong> <?= $game['category'] ?></p>

<!-- 5.4.4 — фотографии -->
