## 4. `Views/WeatherView.axaml` — заполни DataTemplate и Grid

```xml
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WeatherApp.ViewModels"
             xmlns:m="clr-namespace:WeatherApp.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WeatherApp.Views.WeatherView"
             x:DataType="vm:WeatherViewModel">

    <UserControl.DataTemplates>
        <!-- Карточка погоды — заполняем как требует ТЗ -->
        <DataTemplate DataType="m:Weather">
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4">
                <StackPanel Spacing="4">

                    <!-- Иконка + название города -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Image Source="{Binding Image^}" Width="50" Height="50"/>
                        <TextBlock Text="{Binding City.Name}" FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Описание -->
                    <TextBlock Text="{Binding Description}"/>

                    <!-- Температура -->
                    <TextBlock>
                        <Run Text="Температура: "/>
                        <Run Text="{Binding Temperature, StringFormat='{}{0:F0} °C'}"/>
                    </TextBlock>

                    <!-- Ощущается -->
                    <TextBlock>
                        <Run Text="Ощущается как: "/>
                        <Run Text="{Binding FeelsAsTemperature, StringFormat='{}{0:F0} °C'}"/>
                    </TextBlock>

                    <!-- Давление — переводим гПа в мм рт.ст. через StringFormat не выйдет, 
                         поэтому просто показываем гПа, конвертер не требует ТЗ обязательно -->
                    <TextBlock>
                        <Run Text="Давление: "/>
                        <Run Text="{Binding Pressure, StringFormat='{}{0:F0} гПа'}"/>
                    </TextBlock>

                    <!-- Влажность -->
                    <TextBlock>
                        <Run Text="Влажность: "/>
                        <Run Text="{Binding Humidity, StringFormat='{}{0:F0} %'}"/>
                    </TextBlock>

                    <!-- Ветер -->
                    <TextBlock>
                        <Run Text="Ветер: "/>
                        <Run Text="{Binding WindSpeed, StringFormat='{}{0:F1} м/с'}"/>
                    </TextBlock>

                    <!-- Облачность -->
                    <TextBlock>
                        <Run Text="Облачность: "/>
                        <Run Text="{Binding Cloudiness, StringFormat='{}{0:F0} %'}"/>
                    </TextBlock>

                    <!-- Дождь (показываем только если > 0) -->
                    <TextBlock IsVisible="{Binding Rain, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Run Text="Дождь: "/>
                        <Run Text="{Binding Rain, StringFormat='{}{0:F1} мм/ч'}"/>
                    </TextBlock>

                    <!-- Снег -->
                    <TextBlock IsVisible="{Binding Snow, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Run Text="Снег: "/>
                        <Run Text="{Binding Snow, StringFormat='{}{0:F1} мм/ч'}"/>
                    </TextBlock>

                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,*">

        <!-- Поле ввода + кнопка -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="10">
            <TextBox Watermark="Введите город" Text="{Binding CityInput}" Width="250"/>
            <Button Content="Поиск" Command="{Binding SearchCommand}"/>
        </StackPanel>

        <!-- Карточка погоды — ContentControl сам использует DataTemplate выше -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentWeather}"
                        Margin="10"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"/>

    </Grid>
</UserControl>
```

