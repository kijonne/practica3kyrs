import tkinter as tk
from tkinter import ttk, messagebox
import threading
import time
import random

class TaskManager:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Диспетчер задач")
        self.root.geometry("600x400")
        
        self.processes = {}      # pid: {"name": , "thread": }
        self.next_id = 1
        
        self.create_widgets()

    def create_widgets(self):
        tk.Label(self.root, text="Диспетчер задач", font=("Arial", 14, "bold")).pack(pady=10)
        
        # Кнопки
        btn_frame = tk.Frame(self.root)
        btn_frame.pack(pady=10)
        
        tk.Button(btn_frame, text="Запустить новый процесс", 
                 command=self.start_new_process, width=25).pack(side=tk.LEFT, padx=10)
        
        tk.Button(btn_frame, text="Завершить процесс", 
                 command=self.kill_selected_process, width=25).pack(side=tk.LEFT, padx=10)

        # Таблица (только ID и Название)
        columns = ("ID", "Название задачи")
        self.tree = ttk.Treeview(self.root, columns=columns, show="headings", height=12)
        
        self.tree.heading("ID", text="ID")
        self.tree.heading("Название задачи", text="Название задачи")
        
        self.tree.column("ID", width=80, anchor="center")
        self.tree.column("Название задачи", width=400)
        
        self.tree.pack(pady=10, padx=20, fill=tk.BOTH, expand=True)

    def start_new_process(self):
        name = f"Задача-{self.next_id:03d}"
        
        t = threading.Thread(target=self.simulate_process, args=(self.next_id,), daemon=True)
        t.start()
        
        self.processes[self.next_id] = {"name": name, "thread": t}
        self.next_id += 1
        self.update_list()

    def simulate_process(self, pid):
        # Имитация работы процесса (от 5 до 20 секунд)
        time.sleep(random.randint(5, 20))
        # После завершения автоматически удаляем из списка
        if pid in self.processes:
            del self.processes[pid]
            self.update_list()

    def kill_selected_process(self):
        selected = self.tree.selection()
        if not selected:
            messagebox.showwarning("Внимание", "Сначала выберите процесс!")
            return
        
        pid = int(self.tree.item(selected[0])['values'][0])
        
        if pid in self.processes:
            del self.processes[pid]
            messagebox.showinfo("Завершено", f"Процесс {pid} завершён")
            self.update_list()

    def update_list(self):
        # Очищаем таблицу
        for item in self.tree.get_children():
            self.tree.delete(item)
        
        for pid, info in self.processes.items():
            self.tree.insert("", "end", values=(pid, info["name"]))

    def run(self):
        self.root.mainloop()


# ====================== ЗАПУСК ======================
if __name__ == "__main__":
    app = TaskManager()
    app.run()
