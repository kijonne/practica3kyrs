### 3. UserCredentials.cs (папка ViewModels)
```csharp
using CommunityToolkit.Mvvm.ComponentModel;
using System.ComponentModel.DataAnnotations;

namespace HelloApp.ViewModels;

public partial class UserCredentials : ObservableValidator
{
    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Логин обязателен")]
    [MinLength(3, ErrorMessage = "Минимум 3 символа")]
    [MaxLength(20, ErrorMessage = "Максимум 20 символов")]
    [RegularExpression(@"^[a-zA-Z0-9_]+$", ErrorMessage = "Только латинские буквы, цифры и нижнее подчёркивание")]
    public partial string Login { get; set; } = string.Empty;

    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Пароль обязателен")]
    [MinLength(8, ErrorMessage = "Пароль должен быть не менее 8 символов")]
    [RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\W).{8,}$", 
        ErrorMessage = "Пароль должен содержать заглавные и строчные латинские буквы + спецсимвол")]
    public partial string Password { get; set; } = string.Empty;

    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Подтверждение пароля обязательно")]
    [Compare(nameof(Password), ErrorMessage = "Пароли не совпадают")]
    public partial string ConfirmPassword { get; set; } = string.Empty;

    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Email обязателен")]
    [EmailAddress(ErrorMessage = "Некорректный email")]
    public partial string Email { get; set; } = string.Empty;

    [ObservableProperty]
    [NotifyDataErrorInfo]
    [Required(ErrorMessage = "Номер телефона обязателен")]
    [RegularExpression(@"^\+?\d{10,15}$", ErrorMessage = "Некорректный номер телефона (пример: +79991234567)")]
    public partial string PhoneNumber { get; set; } = string.Empty;
}
```

