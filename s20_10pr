<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HelloApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="650"
             x:Class="HelloApp.Views.RegistrationView"
             x:DataType="vm:RegistrationViewModel">

    <ScrollViewer>
        <StackPanel Spacing="20" Margin="40" MaxWidth="500">

            <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />

            <!-- Логин -->
            <StackPanel Spacing="5">
                <TextBlock Text="Логин" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="Введите логин" 
                             Text="{Binding Credentials.Login}" />
                </DataValidationErrors>
            </StackPanel>

            <!-- Пароль -->
            <StackPanel Spacing="5">
                <TextBlock Text="Пароль" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="Введите пароль" PasswordChar="•"
                             Text="{Binding Credentials.Password}" />
                </DataValidationErrors>
            </StackPanel>

            <!-- Подтверждение пароля -->
            <StackPanel Spacing="5">
                <TextBlock Text="Подтверждение пароля" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="Повторите пароль" PasswordChar="•"
                             Text="{Binding Credentials.ConfirmPassword}" />
                </DataValidationErrors>
            </StackPanel>

            <!-- Email -->
            <StackPanel Spacing="5">
                <TextBlock Text="Email" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="your@email.com" 
                             Text="{Binding Credentials.Email}">
                        <TextBox.TextInputOptions>
                            <TextInputOptions ContentType="Email" />
                        </TextBox.TextInputOptions>
                    </TextBox>
                </DataValidationErrors>
            </StackPanel>

            <!-- Телефон -->
            <StackPanel Spacing="5">
                <TextBlock Text="Номер телефона" FontWeight="Bold" />
                <DataValidationErrors>
                    <TextBox Watermark="+7 (999) 123-45-67" 
                             Text="{Binding Credentials.PhoneNumber}" />
                </DataValidationErrors>
            </StackPanel>

            <!-- Кнопка для проверки (по желанию) -->
            <Button Content="Зарегистрироваться" 
                    HorizontalAlignment="Center"
                    Padding="30,12"
                    FontSize="16"
                    Command="{Binding SubmitCommand}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
```

