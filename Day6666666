## Задание 5.1 — Метод для выборки таблицы (DataTable)

### 5.1.1 — Добавь метод в класс DAL.cs

```csharp
using MySql.Data.MySqlClient;
using System.Data;

public static class DAL
{
    public static string Server = "localhost";
    public static string Port = "3306";
    public static string Database = "market";
    public static string UserID = "root";
    public static string Password = "";

    public static string GetConnectionString()
    {
        var stringBuilder = new MySqlConnectionStringBuilder();
        stringBuilder.Server = Server;
        stringBuilder.Port = uint.Parse(Port);
        stringBuilder.UserID = UserID;
        stringBuilder.Password = Password;
        stringBuilder.Database = Database;
        return stringBuilder.ConnectionString;
    }

    // 5.1.1 — метод возвращающий DataTable
    public static DataTable GetTable(string query)
    {
        DataTable table = new DataTable();
        using (MySqlConnection connection = new MySqlConnection(GetConnectionString()))
        {
            connection.Open();
            MySqlCommand command = new MySqlCommand(query, connection);
            table.Load(command.ExecuteReader());
        }
        return table;
    }

    // 5.2.1 — метод возвращающий одно значение
    public static object GetScalar(string query)
    {
        using (MySqlConnection connection = new MySqlConnection(GetConnectionString()))
        {
            connection.Open();
            MySqlCommand command = new MySqlCommand(query, connection);
            return command.ExecuteScalar();
        }
    }
}
```

