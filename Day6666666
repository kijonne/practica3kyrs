using System.Windows;

public partial class MainWindow : Window
{
    public MainWindow()
    {
        InitializeComponent();
    }

    // 5.1.2 — выполнить любую SQL команду
    private void btnExecute_Click(object sender, RoutedEventArgs e)
    {
        try
        {
            int rows = DAL.ExecuteQuery(txtQuery.Text);
            lblQueryResult.Text = $"Выполнено! Изменено строк: {rows}";
        }
        catch (Exception ex)
        {
            lblQueryResult.Text = $"Ошибка: {ex.Message}";
        }
    }

    // 5.2 — удалить книгу по коду
    private void btnDelete_Click(object sender, RoutedEventArgs e)
    {
        try
        {
            string query = $"DELETE FROM books WHERE book_id = {txtDeleteId.Text}";
            int rows = DAL.ExecuteQuery(query);
            if (rows > 0)
                lblDeleteResult.Text = $"Книга с кодом {txtDeleteId.Text} удалена!";
            else
                lblDeleteResult.Text = "Книга с таким кодом не найдена.";
        }
        catch (Exception ex)
        {
            lblDeleteResult.Text = $"Ошибка: {ex.Message}";
        }
    }

    // 5.3 — добавить новую книгу
    private void btnInsert_Click(object sender, RoutedEventArgs e)
    {
        try
        {
            string query = $"INSERT INTO books " +
                           $"(author_id, title, genre, price, weight, pages, publish_year) " +
                           $"VALUES ({txtAuthorId.Text}, " +
                           $"'{txtTitle.Text}', " +
                           $"'{txtGenre.Text}', " +
                           $"{txtPrice.Text}, " +
                           $"{txtWeight.Text}, " +
                           $"{txtPages.Text}, " +
                           $"{txtYear.Text})";

            int rows = DAL.ExecuteQuery(query);
            lblInsertResult.Text = $"Книга '{txtTitle.Text}' добавлена!";
        }
        catch (Exception ex)
        {
            lblInsertResult.Text = $"Ошибка: {ex.Message}";
        }
    }
}
