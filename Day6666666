## Задание 5.4 — Python изменение цены книги

Создай файл `update_price.py`:

```python
import mysql.connector

try:
    conn = mysql.connector.connect(
        host="localhost",
        user="root",
        passwd="",      # твой пароль
        db="market"
    )

    cursor = conn.cursor()

    # Пользователь вводит код и новую цену
    book_id = input("Введите код книги: ")
    new_price = input("Введите новую цену: ")

    # Выполняем DML запрос
    cursor.execute(
        "UPDATE books SET price = %s WHERE book_id = %s",
        (new_price, book_id)
    )

    # Сохраняем транзакцию
    conn.commit()
    print(f"Цена книги {book_id} изменена на {new_price}!")

    # Проверяем результат
    cursor.execute("SELECT book_id, title, price FROM books WHERE book_id = %s", (book_id,))
    results = cursor.fetchall()
    print("\nРезультат:")
    for row in results:
        print(f"ID: {row[0]} | Название: {row[1]} | Цена: {row[2]}")

    conn.close()

except mysql.connector.Error as e:
    print(f"Ошибка: {e}")
```

