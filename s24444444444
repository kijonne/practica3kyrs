#### `MainWindow.axaml.cs`
```csharp
using Avalonia.Controls;
using System.Collections.Generic;

namespace AvaloniaStylesLab;

public partial class MainWindow : Window
{
    public MainWindow()
    {
        InitializeComponent();

        var operations = new List<MoneyOperation>
        {
            new MoneyOperation { Description = "Зарплата", Amount = 85000, IsIncome = true },
            new MoneyOperation { Description = "Продукты", Amount = 3200, IsIncome = false },
            new MoneyOperation { Description = "Фриланс", Amount = 25000, IsIncome = true },
            new MoneyOperation { Description = "Такси", Amount = 950, IsIncome = false }
        };

        DataContext = new { Operations = operations };
    }
}
```

