### Задание 5.3 — Список книг автора по его id

```sql
DELIMITER //
CREATE FUNCTION get_author_books(p_author_id INT)
RETURNS TEXT
DETERMINISTIC
READS SQL DATA
BEGIN
    DECLARE result TEXT;
    
    SELECT GROUP_CONCAT(title ORDER BY title SEPARATOR ', ')
    INTO result
    FROM books
    WHERE author_id = p_author_id;
    
    RETURN result;
END //
DELIMITER ;

-- Проверка (подставь реальный author_id):
SELECT get_author_books(1);
```

